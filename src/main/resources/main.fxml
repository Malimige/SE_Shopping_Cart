<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="TOP_LEFT" xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label fx:id="selectLanguageLabel" text="Select the language:"/>
    <ComboBox fx:id="languageBox" onAction="#handleLanguageChange"/>
    <Button fx:id="confirmButton" text="Confirm Language" onAction="#handleConfirmLanguage"/>

    <Label fx:id="itemNumberLabel" text="Item Number:"/>
    <TextField fx:id="itemNumberField" promptText="Item Number"/>

    <Label fx:id="priceLabel" text="Price:"/>
    <TextField fx:id="priceField" promptText="Price"/>

    <Label fx:id="quantityLabel" text="Quantity:"/>
    <TextField fx:id="quantityField" promptText="Quantity"/>

    <Button fx:id="addItemButton" text="Add Item" onAction="#handleAddItem"/>
    <Button fx:id="calculateTotalButton" text="Calculate Total" onAction="#handleCalculateTotal"/>

    <TextArea fx:id="cartDisplayArea" prefHeight="150" editable="false"/>
    <Label fx:id="totalLabel" text="Total:"/>
</VBox>